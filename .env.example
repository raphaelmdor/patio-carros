# ─── Banco de Dados MySQL ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=patio_carros

# ─── API do DETRAN ───────────────────────────────────────────────────────────
# Sem as variáveis abaixo, o sistema usa dados de demonstração (mock).
# Provedores compatíveis: ApiCarros, ConsultaPlacas, PlacaFipe, etc.
# Formato esperado: GET {DETRAN_API_URL}/{PLACA} com header Authorization: Bearer {DETRAN_API_KEY}

DETRAN_API_URL=https://api.seuprovedor.com.br/placa
DETRAN_API_KEY=sua_chave_aqui

# ─── Ambiente ────────────────────────────────────────────────────────────────
NODE_ENV=development
